# Copy to .env and fill in real values. NEVER commit .env or real credentials.
# These are exactly the variables to set in Vercel → Project → Settings →
# Environment Variables (Fase 8). The Neon Vercel integration provides both URLs.

# Neon POOLED connection string (host contains "-pooler"). Used by Prisma at
# runtime (datasource `url`). Keep pgbouncer=true so Prisma works over PgBouncer.
DATABASE_URL=postgresql://USER:PASSWORD@ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# Neon UNPOOLED / direct connection string (host WITHOUT "-pooler"). Used by
# Prisma for migrations (datasource `directUrl`). PgBouncer can't run migrations.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require

# football-data.org v4 API token (free tier — verified to return WC2026).
FOOTBALL_DATA_API_KEY=

# Admin password gating /beheer.
ADMIN_PASSWORD=

# Data provider: "football-data" (primary) or "api-football" (fallback).
DATA_PROVIDER=football-data

# Only needed if DATA_PROVIDER=api-football.
API_FOOTBALL_KEY=
